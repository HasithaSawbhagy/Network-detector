{
  "name": "network-detector",
  "version": "1.3.4",
  "description": "Network Performance Detector Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend && electron-builder --win"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.0.0",
    "electron": "^25.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.network.detector",
    "productName": "Network Detector",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "main.js",
      "backend/**/*",
      "frontend/dist/**/*",
      "assets/**/*",
      "package.json"
    ]
  }
}
